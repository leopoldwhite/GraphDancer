###############################################################################
# GraphDancer environment variables (example)
#
# Source this file in your shell, or copy values into your own environment.
# DO NOT commit real secrets.
###############################################################################

# Optional: Weights & Biases (only if you enable wandb logging)
# export WANDB_API_KEY=""

# Optional: Hugging Face token (only if downloading gated models)
# export HF_TOKEN=""

# Optional: OpenAI API key (only used by eval.py GPT-based scoring)
# export OPENAI_API_KEY=""

# Recommended paths
# export GRAPH_DIR="./data/graphs"
# export DATA_DIR="./data/grbench_fewshot_merged_biomedical"
# export OUTPUT_DIR="./checkpoints"


